<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout_toolbar"
    android:layout_width="match_parent"
    android:layout_height="?actionBarSize"
    android:background="#18BDB8"
    tools:ignore="ContentDescription">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/optionToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#17FFFFFF"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme" />

    <ImageButton
        android:id="@+id/btn_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:padding="10dp"

        android:visibility="invisible"
        app:srcCompat="@drawable/baseline_menu_24" />


    <ImageView
        android:id="@+id/img_back"
        android:layout_width="@dimen/define_dimen_80"
        android:layout_height="@dimen/define_dimen_80"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/define_dimen_6"
        android:padding="@dimen/define_dimen_20"
        android:src="@drawable/baseline_keyboard_backspace_24"
        android:visibility="visible" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="@string/app_name"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_xnormal" />

    <ImageView
        android:id="@+id/img_cart"
        android:layout_width="@dimen/define_dimen_45"
        android:layout_height="@dimen/define_dimen_45"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="@dimen/define_dimen_4"
        android:padding="@dimen/define_dimen_6"
        android:src="@drawable/baseline_shopping_cart_24"
        android:visibility="visible" />

</RelativeLayout>

