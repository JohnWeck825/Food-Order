<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/define_dimen_4"
    android:layout_marginTop="@dimen/define_dimen_14"
    android:layout_marginEnd="@dimen/define_dimen_4"
    app:cardCornerRadius="@dimen/define_dimen_18"
    app:cardElevation="@dimen/define_dimen_6"
    app:strokeColor="@color/white"
    tools:ignore="ContentDescription">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="@dimen/define_dimen_12">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout_image"
            android:layout_width="@dimen/define_dimen_100"
            android:layout_height="@dimen/define_dimen_100"
            android:layout_marginStart="@dimen/define_dimen_2"
            android:layout_marginTop="@dimen/define_dimen_2"
            android:layout_marginEnd="@dimen/define_dimen_6"
            android:layout_marginBottom="@dimen/define_dimen_2"
            android:background="@color/white"
            app:cardCornerRadius="@dimen/define_dimen_6"
            app:cardElevation="@dimen/define_dimen_8"
            app:strokeColor="@color/light_blue_2">

            <ImageView
                android:id="@+id/img_food_cart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/define_dimen_10"
            android:layout_marginEnd="@dimen/define_dimen_5"
            android:layout_toStartOf="@+id/cardView_tv_delete"
            android:layout_toEndOf="@+id/layout_image"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_food_name_cart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="@string/app_name"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_food_price_cart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="@string/app_name"
                android:textColor="@color/item_grid_food_price"
                android:textSize="@dimen/text_size_small" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="@dimen/define_dimen_5"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_margin="@dimen/define_dimen_10"
                    android:elevation="8dp"
                    app:cardCornerRadius="@dimen/define_dimen_100"
                    app:cardElevation="@dimen/define_dimen_6">

                    <TextView
                        android:id="@+id/tv_subtract"
                        android:layout_width="@dimen/define_dimen_30"
                        android:layout_height="@dimen/define_dimen_30"
                        android:background="@drawable/food_cart_plus"
                        android:gravity="center"
                        android:text="-"
                        android:textColor="@color/black"
                        android:textSize="20sp" />
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_margin="@dimen/define_dimen_10"
                    android:elevation="8dp"
                    app:cardCornerRadius="@dimen/define_dimen_100"
                    app:cardElevation="@dimen/define_dimen_2">

                    <TextView
                        android:id="@+id/tv_count"
                        android:layout_width="@dimen/define_dimen_30"
                        android:layout_height="@dimen/define_dimen_30"
                        android:background="@drawable/food_cart_plus"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_normal" />
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_margin="@dimen/define_dimen_10"
                    android:elevation="8dp"
                    app:cardCornerRadius="@dimen/define_dimen_100"
                    app:cardElevation="@dimen/define_dimen_6">

                    <TextView
                        android:id="@+id/tv_add"
                        android:layout_width="@dimen/define_dimen_30"
                        android:layout_height="@dimen/define_dimen_30"
                        android:background="@drawable/food_cart_plus"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/black"
                        android:textSize="20sp" />
                </androidx.cardview.widget.CardView>


            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardView_tv_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/define_dimen_6"
            android:layout_marginTop="@dimen/define_dimen_6"
            android:layout_marginEnd="@dimen/define_dimen_6"
            android:layout_marginBottom="@dimen/define_dimen_6"
            android:elevation="8dp"
            app:cardCornerRadius="@dimen/define_dimen_10"
            app:cardElevation="@dimen/define_dimen_6"
            app:strokeColor="@color/red">

            <ImageButton
                android:id="@+id/tv_delete"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@color/white"
                android:gravity="center"
                android:src="@drawable/delete_cart"
                android:textColor="@color/white" />
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>


</com.google.android.material.card.MaterialCardView>
